{
  "info": {
    "_postman_id": "081dbb37-2d74-480d-97a2-23f61f35d9b7",
    "name": "GearUp API",
    "description": "Full flow: register -> login -> categories -> gear -> rental order -> payment -> review -> admin oversight.\n\nRun requests top to bottom within each folder. Tokens and IDs are auto-captured into collection variables by each request's Tests script, so later requests don't need manual copy-pasting.\n\nAdmin account cannot self-register (by design) -- seed one directly in the DB, then fill in adminEmail/adminPassword variables before running the Admin folder.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "51744086"
  },
